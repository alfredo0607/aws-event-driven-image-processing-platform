---
import Layout from '../layouts/Layout.astro';
import { ImageProcessor } from '../components/ImageProcessor';
---

<Layout title="AWS Image Processing Platform">
  <div class="max-w-5xl mx-auto px-4 py-10 space-y-12">

    <!-- ── Header ─────────────────────────────────────────────────── -->
    <header class="space-y-3">
      <p class="text-xs font-mono text-violet-400 tracking-widest uppercase">Arquitectura 03</p>
      <h1 class="text-3xl font-bold tracking-tight text-slate-100">
        Event-Driven Serverless<br />Image Processing
      </h1>
      <p class="text-slate-400 max-w-2xl">
        Demo de una arquitectura orientada a eventos en AWS donde el procesamiento de im&aacute;genes
        ocurre de forma as&iacute;ncrona, desacoplada y sin gestionar servidores.
      </p>
    </header>

    <!-- ── Qué es y qué se busca demostrar ───────────────────────── -->
    <section class="grid md:grid-cols-2 gap-6">

      <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 space-y-3">
        <h2 class="text-sm font-semibold text-slate-200 uppercase tracking-wide">
          Qu&eacute; es esta demo
        </h2>
        <p class="text-slate-400 text-sm leading-relaxed">
          Una plataforma que recibe im&aacute;genes a trav&eacute;s de una API REST, las almacena en
          <strong class="text-slate-300">Amazon S3</strong> y desencadena autom&aacute;ticamente un
          pipeline serverless que genera tres versiones redimensionadas:
          <span class="text-slate-300">800&times;600</span>,
          <span class="text-slate-300">400&times;300</span> y
          <span class="text-slate-300">150&times;150</span>.
          Los metadatos del procesamiento se persisten en
          <strong class="text-slate-300">DynamoDB</strong> y se env&iacute;a una notificaci&oacute;n
          v&iacute;a <strong class="text-slate-300">SNS</strong>.
        </p>
      </div>

      <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 space-y-3">
        <h2 class="text-sm font-semibold text-slate-200 uppercase tracking-wide">
          Qu&eacute; se busca demostrar
        </h2>
        <ul class="text-slate-400 text-sm leading-relaxed space-y-2">
          <li class="flex gap-2">
            <span class="text-violet-400 mt-0.5">&#x25B6;</span>
            <span>
              <strong class="text-slate-300">Desacoplamiento</strong> mediante SQS como buffer entre el
              evento de S3 y la ejecuci&oacute;n de Lambda.
            </span>
          </li>
          <li class="flex gap-2">
            <span class="text-violet-400 mt-0.5">&#x25B6;</span>
            <span>
              <strong class="text-slate-300">Resiliencia</strong> con reintentos autom&aacute;ticos
              (hasta 3) y Dead-Letter Queue para mensajes fallidos.
            </span>
          </li>
          <li class="flex gap-2">
            <span class="text-violet-400 mt-0.5">&#x25B6;</span>
            <span>
              <strong class="text-slate-300">Escalabilidad</strong> sin provisionamiento: Lambda escala
              autom&aacute;ticamente seg&uacute;n la carga de uploads.
            </span>
          </li>
          <li class="flex gap-2">
            <span class="text-violet-400 mt-0.5">&#x25B6;</span>
            <span>
              <strong class="text-slate-300">Contenido privado</strong> servido de forma segura mediante
              URLs firmadas de CloudFront.
            </span>
          </li>
        </ul>
      </div>

    </section>

    <!-- ── Pipeline paso a paso ──────────────────────────────────── -->
    <section class="space-y-4">
      <h2 class="text-sm font-semibold text-slate-200 uppercase tracking-wide">
        C&oacute;mo funciona el pipeline
      </h2>
      <ol class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {[
          {
            n: '01',
            service: 'API + S3',
            title: 'Upload',
            desc: 'El usuario sube la imagen vía API REST. El backend la deposita en el bucket S3 de input bajo el prefijo image-resize/input/.',
          },
          {
            n: '02',
            service: 'S3 Event Notification',
            title: 'Evento disparado',
            desc: 'S3 emite un evento s3:ObjectCreated:* con entrega at-least-once hacia SQS en cuanto el objeto está disponible.',
          },
          {
            n: '03',
            service: 'SQS',
            title: 'Buffer y retry',
            desc: 'SQS actúa como buffer. VisibilityTimeout = 6× el timeout de Lambda. Tras 3 fallos el mensaje pasa a la DLQ.',
          },
          {
            n: '04',
            service: 'Lambda (Python + Pillow)',
            title: 'Procesamiento',
            desc: 'Lambda descarga la imagen en memoria, genera 3 versiones con Pillow y las sube a S3 output bajo resized/.',
          },
          {
            n: '05',
            service: 'DynamoDB',
            title: 'Persistencia',
            desc: 'Lambda registra el resultado en DynamoDB: status, rutas S3 de las versiones, dimensiones originales y timestamp.',
          },
          {
            n: '06',
            service: 'SNS + CloudFront',
            title: 'Notificación y acceso',
            desc: 'SNS notifica el resultado (email/webhook). Las imágenes se sirven vía CloudFront con URLs firmadas (expiran en 24 h).',
          },
        ].map((step) => (
          <li class="bg-slate-900 border border-slate-800 rounded-2xl p-5 space-y-2">
            <div class="flex items-center justify-between">
              <span class="text-xs font-mono text-violet-400">{step.n}</span>
              <span class="text-xs text-slate-600 font-medium">{step.service}</span>
            </div>
            <p class="text-sm font-semibold text-slate-200">{step.title}</p>
            <p class="text-xs text-slate-500 leading-relaxed">{step.desc}</p>
          </li>
        ))}
      </ol>
    </section>

    <!-- ── Stack de servicios ─────────────────────────────────────── -->
    <section class="space-y-4">
      <h2 class="text-sm font-semibold text-slate-200 uppercase tracking-wide">
        Servicios AWS involucrados
      </h2>
      <div class="flex flex-wrap gap-2">
        {['S3', 'SQS', 'Lambda', 'DynamoDB', 'SNS', 'CloudFront', 'IAM', 'CloudWatch'].map((s) => (
          <span class="px-3 py-1 rounded-full bg-slate-800 border border-slate-700 text-slate-300 text-xs font-medium">
            {s}
          </span>
        ))}
      </div>
    </section>

    <!-- ── Demo interactiva ───────────────────────────────────────── -->
    <section class="space-y-4">
      <div class="border-t border-slate-800 pt-8 space-y-1">
        <h2 class="text-lg font-semibold text-slate-100">Demo interactiva</h2>
        <p class="text-slate-500 text-sm">
          Sube una imagen y observa c&oacute;mo aparece procesada en la galería tras unos segundos.
          Usa el bot&oacute;n <strong class="text-slate-400">Actualizar</strong> para refrescar la galería.
        </p>
      </div>
      <ImageProcessor client:load />
    </section>

    <!-- ── Developer ───────────────────────────────────────────────── -->
    <footer class="border-t border-slate-800 pt-8 pb-4 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div>
        <p class="text-xs text-slate-500 uppercase tracking-widest mb-1">Developer</p>
        <p class="text-sm font-semibold text-slate-200">Alfredo Jose Dominguez Hernandez</p>
      </div>

      <div class="flex items-center gap-3">
        <!-- GitHub -->
        <a
          href="https://github.com/alfredo0607/aws-event-driven-image-processing-platform"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-slate-800 hover:bg-slate-700 border border-slate-700 hover:border-slate-600 text-slate-300 hover:text-white text-sm font-medium transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
            <path d="M12 0C5.37 0 0 5.373 0 12c0 5.303 3.438 9.8 8.205 11.387.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.757-1.333-1.757-1.089-.745.083-.729.083-.729 1.205.084 1.84 1.237 1.84 1.237 1.07 1.834 2.807 1.304 3.492.997.108-.775.418-1.305.762-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.468-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.3 1.23a11.51 11.51 0 0 1 3.003-.404c1.02.005 2.047.138 3.003.404 2.29-1.552 3.297-1.23 3.297-1.23.653 1.652.242 2.873.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.61-2.804 5.625-5.475 5.92.43.372.823 1.102.823 2.222 0 1.606-.015 2.898-.015 3.293 0 .322.216.694.825.576C20.565 21.796 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
          GitHub
        </a>

        <!-- LinkedIn -->
        <a
          href="https://www.linkedin.com/in/alfredo-jose-dominguez-hernandez"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-[#0A66C2] hover:bg-[#0958a8] text-white text-sm font-medium transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
      </div>
    </footer>

  </div>
</Layout>
